  [5]  (PLUS)      "/Users/szzhou/Library/Application Support/Stata/ado/plus/"
  [6]  (OLDPLACE)  "~/ado/"
  [7]              "../../lib/stata"

. set linesize 100

. set scheme stcolor

. 
. * =============================================================================
. 
. program main
  1.     use "../input/mpg.dta", clear
  2.     regression_table
  3.         city_figure
  4.         hwy_figure
  5. end

. 
. program regression_table
  1.     reg displ cty, vce(cluster year)
  2.     estimates store cty_clustered
  3.     
.     reg displ hwy, vce(cluster year)
  4.     estimates store hwy_clustered
  5.     
.     reg displ hwy cty, vce(cluster year)
  6.     estimates store hwy_cty_clustered
  7.     
.     esttab hwy_clustered cty_clustered hwy_cty_clustered ///
>         using ../output/table_reg_clustered.tex, ///
>         cells(b se p) ///
>         replace
  8. end

. 
. program city_figure
  1.         tempvar log_cty
  2.         gen `log_cty' = log(cty)
  3. 
.     scatter `log_cty' displ, xtitle("Engine displacement (L)") ///
>                 ytitle("Log city fuel economy (mpg)") ///
>                 mcolor(year)
  4.         graph export ../output/figure_city.jpg, replace
  5. end

. 
. program hwy_figure
  1.     scatter hwy displ, xtitle("Engine displacement (L)") ///
>                 ytitle("Highway fuel economy (mpg)") ///
>                 mcolor(year)
  2.         graph export ../output/figure_hwy.jpg, replace
  3. end

. 
